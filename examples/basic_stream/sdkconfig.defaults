# PSRAM — required for camera frame buffers on XIAO ESP32S3 Sense
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_FETCH_INSTRUCTIONS=y
CONFIG_SPIRAM_RODATA=y

# Camera orientation — XIAO ESP32S3 Sense (camera mounted upside-down)
CONFIG_CMSTE_VFLIP=y
CONFIG_CMSTE_HMIRROR=n

# WiFi credentials — change these before flashing
CONFIG_EXAMPLE_WIFI_SSID="your-ssid"
CONFIG_EXAMPLE_WIFI_PASSWORD="your-password"
